# test.LANGUAGE — LANGUAGE v2.0.0 Test Suite #

Print "=================================="
Print "  LANGUAGE v2.0.0 Test Suite"
Print "=================================="
Print ""

Print "--- 1. Variables & Types ---"
n = 42
s = "Hello"
b = True
arr = [1, 2, 3]
d = {"name": "James", "age": 21}
x = Null
Print "Number: " + ToString(n)
Print "String: " + s
Print "Boolean: " + ToString(b)
Print "Array: " + ToString(arr)
Print "Dict: " + ToString(d)
Print "Null: " + ToString(x)
Print ""

Print "--- 2. Arithmetic ---"
Print "10 + 3 = " + ToString(10 + 3)
Print "10 - 3 = " + ToString(10 - 3)
Print "10 * 3 = " + ToString(10 * 3)
Print "Power(2, 10) = " + ToString(Power(2, 10))
Print "Sqrt(144) = " + ToString(Sqrt(144))
Print "Mod(17, 5) = " + ToString(Mod(17, 5))
Print ""

Print "--- 3. String Interpolation ---"
iname = "James"
iage = 21
Print "Hello, {iname}!"
Print "You are {iage} years old."
Print "2 + 2 = {2 + 2}"
Print ""

Print "--- 4. Control Flow ---"
score = 85
If score >= 90
  Print "Grade: A"
Elif score >= 80
  Print "Grade: B"
Elif score >= 70
  Print "Grade: C"
Else
  Print "Grade: F"
End

i = 1
total = 0
While i <= 5
  total = total + i
  i = i + 1
End
Print "Sum 1-5 = " + ToString(total)

result = ""
For j = 1 To 5
  result = result + ToString(j) + " "
End
Print "For loop: " + result
Print ""

Print "--- 5. Functions & Defaults ---"
Func Add(a, b)
  Return a + b
End
Func Factorial(fn)
  If fn <= 1
    Return 1
  End
  Return fn * Factorial(fn - 1)
End
Func Greet(gname, greeting = "Hello")
  Return "{greeting}, {gname}!"
End
Print "Add(3, 4) = " + ToString(Add(3, 4))
Print "Factorial(6) = " + ToString(Factorial(6))
Print "Greet(James) = " + Greet("James")
Print "Greet(James, Hey) = " + Greet("James", "Hey")
Print ""

Print "--- 6. Dictionaries ---"
person = {"name": "James", "age": 21}
Print person["name"]
person["age"] = 22
Print ToString(person["age"])
Print ToString(DictKeys(person))
Print ToString(DictHas(person, "name"))
Print ToString(DictSize(person))
d1 = {"a": 1, "b": 2}
d2 = {"b": 99, "c": 3}
Print ToString(DictMerge(d1, d2))
Print ""

Print "--- 7. Null ---"
nothing = Null
Print ToString(IsNull(nothing))
If nothing == Null
  Print "nothing is Null"
End
Print ""

Print "--- 8. JSON ---"
jdata = {"name": "LANGUAGE", "version": 2, "cool": True}
jstr = JsonStringify(jdata)
Print jstr
jparsed = JsonParse(jstr)
Print jparsed["name"]
Print ToString(jparsed["version"])
Print ""

Print "--- 9. Type Checks ---"
Print ToString(IsNumber(42))
Print ToString(IsString("hi"))
Print ToString(IsBool(True))
Print ToString(IsArray([1, 2]))
Print ToString(IsDict({}))
Print ToString(IsNull(Null))
Print ""

Print "--- 10. Error Handling ---"
Try
  bad = 1 / 0
Catch(err)
  Print "Caught: " + err
End
Print ""

Print "--- 11. File I/O ---"
WriteFile("test_out.txt", "Hello from LANGUAGE!")
content = ReadFile("test_out.txt")
Print content
AppendFile("test_out.txt", " Appended.")
Print ReadFile("test_out.txt")
Print ""

Print "--- 12. DNS ---"
Print DnsResolve("localhost")
Print DnsReverse("127.0.0.1")
Print ""

Print "--- 13. TCP ---"
srv = SocketListen("0.0.0.0", 19876)
cli = SocketConnect("127.0.0.1", 19876)
con = SocketAccept(srv)
SocketSend(cli, "Hello TCP!")
Print SocketReceive(con)
SocketClose(cli)
SocketClose(con)
SocketClose(srv)
Print ""

Print "--- 14. UDP ---"
ur = UdpCreate(19877)
us = UdpCreate(0)
UdpSetTimeout(ur, 1000)
UdpSend(us, "127.0.0.1", 19877, "Hello UDP!")
Print UdpReceive(ur)
UdpClose(us)
UdpClose(ur)
Print ""

Print "=================================="
Print "  All tests passed!"
Print "=================================="
