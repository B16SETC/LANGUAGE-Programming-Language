# Day 5 tests - For loop #
For i = 1 To 5
  Print i
End

# Array tests #
nums = [10, 50, 30, 20, 99]
nums[2] = 99
Print nums[0]
Print nums[4]
Print nums[2]
Print Length(nums)

# Push and Pop #
arr = [1, 2, 3]
Push(arr, 4)
Print Length(arr)
Pop(arr)
Print Length(arr)

# Elif test #
x = 50
If x < 10
  Print "small"
Elif x < 100
  Print "medium"
Else
  Print "large"
End

# Booleans #
a = True
b = False
Print a
Print b

# Logical operators #
If True And Not False
  Print "logic works"
End
If True Or False
  Print "or works"
End

# Day 6 tests - Type conversion #
n = ToNumber("42")
Print n
s = ToString(100)
Print s

# Math built-ins #
Print Floor(4.9)
Print Ceil(4.1)
Print Sqrt(16)
Print Abs(-7)
Print Power(2, 8)

# Try / Catch #
Try
  x = ToNumber("not a number")
Catch(err)
  Print "caught error"
End

# File I/O #
WriteFile("test_output.txt", "Hello from LANGUAGE 1.0.0!")
contents = ReadFile("test_output.txt")
Print contents
AppendFile("test_output.txt", " Appended!")
